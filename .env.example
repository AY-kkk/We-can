# ===== Backend =====
# App
APP_NAME=We-can
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# CORS (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (default: local sqlite file). Switch to Postgres via DATABASE_URL.
DATABASE_URL=sqlite+aiosqlite:///./wecan.db

# ===== Providers =====
# LLM provider: mock | openai_like
LLM_PROVIDER=mock
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Search provider: mock | http
SEARCH_PROVIDER=mock
SEARCH_API_BASE=
SEARCH_API_KEY=

# Transcriber provider: mock | http
TRANSCRIBER_PROVIDER=mock
TRANSCRIBER_API_BASE=
TRANSCRIBER_API_KEY=

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=15

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost:8000
